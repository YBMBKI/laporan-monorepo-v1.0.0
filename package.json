{
  "name": "ybmbki-laporan-excel-template",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev -w @ybmbki/api",
    "dev:web": "npm run dev -w @ybmbki/web-admin",
    "build": "npm run build -w @ybmbki/api && npm run build -w @ybmbki/web-admin",
    "start:api": "npm run start -w @ybmbki/api",
    "start:web": "npm run start -w @ybmbki/web-admin",
    "lint": "npm run lint -w @ybmbki/api && npm run lint -w @ybmbki/web-admin",
    "test": "npm run test -w @ybmbki/api"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
