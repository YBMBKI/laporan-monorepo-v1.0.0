generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  super_admin
  admin_yayasan
  koordinator
  anggota
  viewer
}

enum PeriodType {
  harian
  mingguan
}

enum ImportStatus {
  draft
  validated
  imported
  rejected
  partial_success
}

enum ValidationStatus {
  valid
  invalid
  warning
}

enum PayrollPeriodStatus {
  draft
  generated
  closed
}

enum OrderStatusType {
  pending
  cancel
  terkirim
  deal
}

// ==================== AUTH ====================

model User {
  id           String    @id @default(cuid())
  fullName     String    @map("full_name")
  email        String    @unique
  username     String    @unique
  passwordHash String    @map("password_hash")
  role         UserRole  @default(anggota)
  memberId     String?   @unique @map("member_id")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  member        Member?        @relation(fields: [memberId], references: [id])
  imports       Import[]
  activities    Activity[]
  payrollPeriods PayrollPeriod[]
  auditLogs     AuditLog[]

  @@map("users")
}

model FoundationSettings {
  id                    String   @id @default(cuid())
  foundationName        String   @map("foundation_name")
  officeName            String   @map("office_name")
  officeAddress         String   @map("office_address")
  city                  String
  province              String
  phone                 String
  email                 String
  reportHeaderLogo      String?  @map("report_header_logo")
  reportSignatureName   String?  @map("report_signature_name")
  reportSignatureTitle  String?  @map("report_signature_title")
  reportFooterNotes     String?  @map("report_footer_notes")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("foundation_settings")
}

// ==================== MASTER DATA ====================

model Branch {
  id              String    @id @default(cuid())
  kodeCabang      String    @unique @map("kode_cabang")
  wilayahKelompok String   @map("wilayah_kelompok")
  wilayahKabupaten String  @map("wilayah_kabupaten")
  wilayahProvinsi String   @map("wilayah_provinsi")
  alamatCabang    String?  @map("alamat_cabang")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  members         Member[]
  activities      Activity[]

  @@map("branches")
}

model Member {
  id              String    @id @default(cuid())
  kodeAnggota     String    @unique @map("kode_anggota")
  namaAnggota     String    @map("nama_anggota")
  branchId        String    @map("branch_id")
  positionId      String    @map("position_id")
  noHp            String?   @map("no_hp")
  alamat          String?
  statusAktif     Boolean   @default(true) @map("status_aktif")
  joinedAt        DateTime  @default(now()) @map("joined_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  branch          Branch           @relation(fields: [branchId], references: [id])
  position        MemberPosition  @relation(fields: [positionId], references: [id])
  user            User?
  activityMembers ActivityMember[]
  orders          Order[]
  memberPayrolls  MemberPayroll[]

  @@map("members")
}

model MemberPosition {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")

  members     Member[]

  @@map("member_positions")
}

model ActivityPosition {
  id                  String    @id @default(cuid())
  code                String    @unique
  name                String
  incentivePerDeal    Int       @default(0) @map("incentive_per_deal")
  isActive            Boolean   @default(true) @map("is_active")

  activityMembers     ActivityMember[]
  payrollRules        PayrollRule[]

  @@map("activity_positions")
}

model Product {
  id               String    @id @default(cuid())
  kodeProduk       String    @unique @map("kode_produk")
  namaProduk       String    @map("nama_produk")
  kategori         String?
  hargaDefault      Int       @default(0) @map("harga_default")
  pointThrDefault   Int       @default(1) @map("point_thr_default")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  orders           Order[]

  @@map("products")
}

model OrderStatus {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String
  sortOrder   Int           @default(0) @map("sort_order")
  isFinal     Boolean       @default(false) @map("is_final")
  isDeal      Boolean       @default(false) @map("is_deal")
  colorTag    String?       @map("color_tag")

  orders      Order[]

  @@map("order_statuses")
}

model Golongan {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")

  orders      Order[]

  @@map("golongans")
}

// ==================== TRANSACTIONS ====================

model Activity {
  id                String      @id @default(cuid())
  tanggal_kegiatan  DateTime    @map("tanggal_kegiatan")
  nama_kegiatann    String      @map("nama_kegiatann")
  branchId          String      @map("branch_id")
  coordinatorId     String      @map("coordinator_id")
  deskripsi         String?
  periodeType        PeriodType  @default(harian) @map("periode_type")
  sourceImportId    String?     @map("source_import_id")
  createdBy         String      @map("created_by")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  branch            Branch        @relation(fields: [branchId], references: [id])
  coordinator        User          @relation(fields: [coordinatorId], references: [id])
  sourceImport       Import?       @relation(fields: [sourceImportId], references: [id])
  activityMembers    ActivityMember[]
  orders             Order[]

  @@map("activities")
}

model ActivityMember {
  id                  String          @id @default(cuid())
  activityId          String          @map("activity_id")
  memberId            String          @map("member_id")
  activityPositionId String          @map("activity_position_id")
  notes               String?

  activity            Activity        @relation(fields: [activityId], references: [id])
  member              Member          @relation(fields: [memberId], references: [id])
  activityPosition    ActivityPosition @relation(fields: [activityPositionId], references: [id])

  @@map("activity_members")
}

model Order {
  id            String      @id @default(cuid())
  activityId    String      @map("activity_id")
  memberId      String?     @map("member_id")
  productId     String      @map("product_id")
  qty           Int         @default(0)
  hargaSatuan   Int         @default(0) @map("harga_satuan")
  totalHarga    Int         @default(0) @map("total_harga")
  golongantId   String?     @map("golongan_id")
  statusId      String      @map("status_id")
  customerName  String?     @map("customer_name")
  notes         String?
  dealAt        DateTime?   @map("deal_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  activity      Activity     @relation(fields: [activityId], references: [id])
  member        Member?      @relation(fields: [memberId], references: [id])
  product       Product      @relation(fields: [productId], references: [id])
  golongant     Golongan?    @relation(fields: [golongantId], references: [id])
  status        OrderStatus  @relation(fields: [statusId], references: [id])

  @@map("orders")
}

// ==================== IMPORT ====================

model Import {
  id            String        @id @default(cuid())
  fileName      String        @map("file_name")
  uploadedBy    String        @map("uploaded_by")
  uploadedAt    DateTime      @default(now()) @map("uploaded_at")
  status        ImportStatus  @default(draft)
  totalRows     Int           @default(0) @map("total_rows")
  validRows     Int           @default(0) @map("valid_rows")
  invalidRows   Int           @default(0) @map("invalid_rows")
  notes         String?
  storagePath   String?       @map("storage_path")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  uploader      User          @relation(fields: [uploadedBy], references: [id])
  importRows    ImportRow[]
  activities    Activity[]

  @@map("imports")
}

model ImportRow {
  id                  String          @id @default(cuid())
  importId            String          @map("import_id")
  rowNumber           Int             @map("row_number")
  payloadJson         Json            @map("payload_json")
  validationStatus    ValidationStatus @default(valid) @map("validation_status")
  validationMessage   String?         @map("validation_message")
  linkedActivityId    String?         @map("linked_activity_id")
  linkedOrderId       String?         @map("linked_order_id")

  import              Import          @relation(fields: [importId], references: [id])

  @@map("import_rows")
}

// ==================== PAYROLL ====================

model PayrollRule {
  id                  String            @id @default(cuid())
  ruleCode            String            @unique @map("rule_code")
  ruleName            String            @map("rule_name")
  activityPositionId  String?           @map("activity_position_id")
  amountType          String            @default("per_deal") @map("amount_type")
  amountValue         Int               @default(0) @map("amount_value")
  isActive            Boolean           @default(true) @map("is_active")
  effectiveStart      DateTime?         @map("effective_start")
  effectiveEnd        DateTime?         @map("effective_end")

  activityPosition    ActivityPosition? @relation(fields: [activityPositionId], references: [id])

  @@map("payroll_rules")
}

model ThrRule {
  id                String    @id @default(cuid())
  ruleCode          String    @unique @map("rule_code")
  pointPerQty       Int       @default(1) @map("point_per_qty")
  rupiahPerPoint    Int       @default(1000) @map("rupiah_per_point")
  isActive          Boolean   @default(true) @map("is_active")
  effectiveStart    DateTime? @map("effective_start")
  effectiveEnd      DateTime? @map("effective_end")

  @@map("thr_rules")
}

model PayrollPeriod {
  id            String               @id @default(cuid())
  periodName    String               @map("period_name")
  month         Int
  year          Int
  startDate     DateTime             @map("start_date")
  endDate       DateTime             @map("end_date")
  status        PayrollPeriodStatus  @default(draft)
  generatedAt   DateTime?            @map("generated_at")
  generatedBy   String?              @map("generated_by")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  generator     User?                 @relation(fields: [generatedBy], references: [id])
  memberPayrolls MemberPayroll[]

  @@map("payroll_periods")
}

model MemberPayroll {
  id               String    @id @default(cuid())
  payrollPeriodId  String    @map("payroll_period_id")
  memberId         String    @map("member_id")
  totalDealCount   Int       @default(0) @map("total_deal_count")
  totalQtyDeal     Int       @default(0) @map("total_qty_deal")
  totalSalesAmount Int       @default(0) @map("total_sales_amount")
  incentiveAmount  Int       @default(0) @map("incentive_amount")
  thrAmount        Int       @default(0) @map("thr_amount")
  otherBonus       Int       @default(0) @map("other_bonus")
  deductionAmount  Int       @default(0) @map("deduction_amount")
  finalAmount      Int       @default(0) @map("final_amount")
  generatedAt     DateTime  @default(now()) @map("generated_at")

  payrollPeriod    PayrollPeriod @relation(fields: [payrollPeriodId], references: [id])
  member           Member         @relation(fields: [memberId], references: [id])

  @@map("member_payrolls")
}

// ==================== AUDIT ====================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  action      String
  entity      String
  entityId    String?  @map("entity_id")
  oldValue   Json?
  newValue   Json?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
